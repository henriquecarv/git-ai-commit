#!/usr/bin/env sh

set -u

ISSUE_PREFIX="AB#"
BODY_LINE_LENGTH=100
AGENT_PROMPT="Write a Conventional Commits message for this diff. Output only the message, with this structure:

1. Subject (first line): <type>[optional scope]: <imperative summary>. Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore. No period at end; keep under 72 characters when possible.
2. Blank line, then body: one or more paragraphs separated by blank lines. Explain what changed and why—not a file list. Wrap so no line exceeds $BODY_LINE_LENGTH characters.
3. Blank line, then footers (if applicable): one key-value pair per line (e.g. Refs: #123, Co-authored-by:, Breaking-Change:). Omit footers you cannot infer from the diff; do not invent reviewers or issue numbers.

Example shape:
fix: prevent racing of requests

Introduce a request id and dismiss stale responses.

Remove obsolete timeouts that mitigated the race.

Refs: #123

Output only the commit message."

usage() {
  cat <<'EOF'
Usage:
  git-ai-commit setup              Configure core.editor and git ai-commit alias
  git-ai-commit [issue-id]         Generate commit message from staged diff
  git-ai-commit --help             Show this help

After setup, use: git ai-commit [issue-id]

Examples:
  git-ai-commit setup
  git ai-commit
  git ai-commit 12345
  git ai-commit AB#12345
EOF
}

# --- Staged diff (lockfiles excluded) ----------------------------------------

capture_staged_diff() {
  diff_file=$(mktemp) || {
    printf 'git-ai-commit: mktemp failed\n' >&2
    exit 1
  }
  git diff --staged -- . \
    ':(exclude)package-lock.json' \
    ':(exclude)yarn.lock' \
    ':(exclude)pnpm-lock.yaml' >"$diff_file" 2>/dev/null

  if [ ! -s "$diff_file" ]; then
    printf 'git-ai-commit: no staged changes to summarize (lockfiles excluded)\n' >&2
    rm -f "$diff_file"
    exit 1
  fi
}

# --- Commit message generation (Cursor or Foundry Local) -----------------------

show_loading_spinner() {
  agent_pid=$1
  spin_i=0
  while kill -0 "$agent_pid" 2>/dev/null; do
    case $spin_i in
      0) c='|' ;;
      1) c='/' ;;
      2) c='-' ;;
      3) c='.' ;;
    esac
    spin_i=$(( (spin_i + 1) % 4 ))
    printf '\rLoading commit message... %s  ' "$c" >&2
    sleep 0.12
  done
  printf '\r\033[K' >&2
}

validate_generated_message() {
  provider_label=$1
  agent_status=$2

  if [ "$agent_status" -ne 0 ]; then
    printf 'git-ai-commit: %s failed\n' "$provider_label" >&2
    exit "$agent_status"
  fi
  if [ -z "$(printf '%s' "$msg" | tr -d '[:space:]')" ]; then
    printf 'git-ai-commit: empty message from agent\n' >&2
    exit 1
  fi
}

generate_commit_message_cursor() {
  msg_file=$(mktemp) || {
    rm -f "$diff_file"
    printf 'git-ai-commit: mktemp failed\n' >&2
    exit 1
  }

  (
    prompt=$(printf '%s\n\n%s\n%s\n' \
      "$AGENT_PROMPT" \
      'Staged diff:' \
      "$(cat "$diff_file")")
    cursor agent -p --trust --mode ask --model auto "$prompt" >"$msg_file"
  ) &
  agent_pid=$!

  show_loading_spinner "$agent_pid"
  wait "$agent_pid"
  agent_status=$?

  msg=$(cat "$msg_file")
  rm -f "$msg_file" "$diff_file"
  validate_generated_message 'cursor agent' "$agent_status"
}

foundry_base_url() {
  if [ -n "${FOUNDRY_BASE_URL:-}" ]; then
    foundry_base=${FOUNDRY_BASE_URL%/}
    return 0
  fi

  if ! command -v foundry >/dev/null 2>&1; then
    printf 'git-ai-commit: foundry: command not found\n' >&2
    exit 1
  fi

  foundry_status=$(foundry service status 2>&1) || {
    printf 'git-ai-commit: foundry service not running; run: foundry model load %s\n' \
      "${FOUNDRY_MODEL:-phi-4-mini}" >&2
    exit 1
  }

  foundry_base=$(printf '%s\n' "$foundry_status" \
    | sed -n 's/.*http:\/\/127\.0\.0\.1:\([0-9]*\)\/.*/http:\/\/127.0.0.1:\1/p' \
    | head -n 1)
  if [ -z "$foundry_base" ]; then
    printf 'git-ai-commit: foundry service not running; run: foundry model load %s\n' \
      "${FOUNDRY_MODEL:-phi-4-mini}" >&2
    exit 1
  fi
}

foundry_model_id() {
  if [ -n "${FOUNDRY_MODEL_ID:-}" ]; then
    foundry_model=$FOUNDRY_MODEL_ID
    return 0
  fi

  if ! command -v foundry >/dev/null 2>&1; then
    printf 'git-ai-commit: foundry: command not found\n' >&2
    exit 1
  fi

  foundry_alias=${FOUNDRY_MODEL:-phi-4-mini}
  foundry_ps=$(foundry service ps 2>&1) || {
    printf 'git-ai-commit: foundry service ps failed; run: foundry service status\n' >&2
    exit 1
  }

  foundry_model=$(printf '%s\n' "$foundry_ps" \
    | awk -v alias="$foundry_alias" '$2 == alias { print $NF; exit }')
  if [ -z "$foundry_model" ]; then
    printf 'git-ai-commit: model %s not loaded; run: foundry model load %s\n' \
      "$foundry_alias" "$foundry_alias" >&2
    exit 1
  fi
}

generate_commit_message_foundry() {
  msg_file=$(mktemp) || {
    rm -f "$diff_file"
    printf 'git-ai-commit: mktemp failed\n' >&2
    exit 1
  }
  payload_file=$(mktemp) || {
    rm -f "$msg_file" "$diff_file"
    printf 'git-ai-commit: mktemp failed\n' >&2
    exit 1
  }
  response_file=$(mktemp) || {
    rm -f "$msg_file" "$payload_file" "$diff_file"
    printf 'git-ai-commit: mktemp failed\n' >&2
    exit 1
  }

  foundry_base_url
  foundry_model_id
  FOUNDRY_MAX_TOKENS=${FOUNDRY_MAX_TOKENS:-2048}
  export AGENT_PROMPT FOUNDRY_MAX_TOKENS

  if ! python3 - "$diff_file" "$foundry_model" "$payload_file" <<'PY'
import json
import os
import sys

with open(sys.argv[1], encoding="utf-8") as diff_file:
    diff = diff_file.read()

payload = {
    "model": sys.argv[2],
    "messages": [
        {"role": "system", "content": os.environ["AGENT_PROMPT"]},
        {"role": "user", "content": "Staged diff:\n" + diff},
    ],
    "temperature": 0.2,
    "max_tokens": int(os.environ.get("FOUNDRY_MAX_TOKENS", "2048")),
}

with open(sys.argv[3], "w", encoding="utf-8") as payload_file:
    json.dump(payload, payload_file)
PY
  then
    rm -f "$msg_file" "$payload_file" "$response_file" "$diff_file"
    printf 'git-ai-commit: python3 required for Foundry backend\n' >&2
    exit 1
  fi

  (
    if ! curl -sf "${foundry_base}/v1/chat/completions" \
      -H "Content-Type: application/json" \
      -d @"$payload_file" \
      -o "$response_file"
    then
      exit 1
    fi
    python3 - "$response_file" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as response_file:
    data = json.load(response_file)

print(data["choices"][0]["message"]["content"], end="")
PY
  ) >"$msg_file" &
  agent_pid=$!

  show_loading_spinner "$agent_pid"
  wait "$agent_pid"
  agent_status=$?

  msg=$(cat "$msg_file")
  rm -f "$msg_file" "$payload_file" "$response_file" "$diff_file"

  if [ "$agent_status" -ne 0 ]; then
    printf 'git-ai-commit: foundry chat completion failed\n' >&2
    exit "$agent_status"
  fi
  validate_generated_message 'foundry chat completion' 0
}

generate_commit_message() {
  case "${GIT_AI_COMMIT_PROVIDER:-cursor}" in
    foundry)
      generate_commit_message_foundry
      ;;
    cursor|*)
      generate_commit_message_cursor
      ;;
  esac
}

# --- Message formatting -------------------------------------------------------

split_title_and_body() {
  title=$(printf '%s\n' "$msg" | head -n 1)
  body=$(printf '%s\n' "$msg" | tail -n +2)
}

wrap_body_to_100_cols() {
  body=$(printf '%s\n' "$body" | while IFS= read -r line || [ -n "$line" ]; do
    if [ -z "$(printf '%s' "$line" | tr -d '[:space:]')" ]; then
      printf '\n'
    else
      printf '%s\n' "$line" | fold -s -w 100
    fi
  done)
}

append_issue_to_title() {
  if [ -z "$issue_id" ]; then
    return 0
  fi
  case $issue_id in
    $ISSUE_PREFIX*) ref=$issue_id ;;
    *) ref="$ISSUE_PREFIX$issue_id" ;;
  esac
  title="$title ($ref)"
}

# --- Commit (editor review + verbose diff) ------------------------------------

run_commit_with_editor() {
  if [ -n "$(printf '%s' "$body" | tr -d '[:space:]')" ]; then
    git commit -ve -m "$title" -m "$body"
  else
    git commit -ve -m "$title"
  fi
}

run_commit_flow() {
  issue_id=${1:-}

  capture_staged_diff
  generate_commit_message
  split_title_and_body
  wrap_body_to_100_cols
  append_issue_to_title
  run_commit_with_editor
}

# --- Script location (follow symlinks) ----------------------------------------

script_real_dir() {
  script=$1
  while [ -L "$script" ]; do
    link=$(readlink "$script") || break
    case $link in
      /*) script=$link ;;
      *) script=$(dirname -- "$script")/$link ;;
    esac
  done
  CDPATH= cd -- "$(dirname -- "$script")" && pwd
}

# --- Main ---------------------------------------------------------------------

case "${1:-}" in
  setup)
    exec "$(script_real_dir "$0")/setup"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    run_commit_flow "$@"
    ;;
esac
