#!/usr/bin/env sh

set -u

DEFAULT_ISSUE_PREFIX="AB#"
BODY_LINE_LENGTH=100

usage() {
  cat <<'EOF'
Usage:
  git-ai-commit setup              Configure core.editor, issue prefix, and git ai-commit alias
  git-ai-commit [issue-id]         Generate commit message from staged diff
  git-ai-commit --help             Show this help

After setup, use: git ai-commit [issue-id]

Examples:
  git-ai-commit setup
  git ai-commit
  git ai-commit 12345
  git ai-commit AB#12345
EOF
}

# --- Staged diff (lockfiles excluded) ----------------------------------------

capture_staged_diff() {
  diff_file=$(mktemp) || {
    printf 'git-ai-commit: mktemp failed\n' >&2
    exit 1
  }
  git diff --staged -- . \
    ':(exclude)package-lock.json' \
    ':(exclude)yarn.lock' \
    ':(exclude)pnpm-lock.yaml' >"$diff_file" 2>/dev/null

  if [ ! -s "$diff_file" ]; then
    printf 'git-ai-commit: no staged changes to summarize (lockfiles excluded)\n' >&2
    rm -f "$diff_file"
    exit 1
  fi
}

# --- Cursor Agent run (diff in prompt) ---------------------------------------

load_agent_prompt() {
  prompt_file="$(script_real_dir "$0")/.agents/SKILLS/CONVENTIONAL_COMMITS.md"
  if [ ! -f "$prompt_file" ]; then
    rm -f "$diff_file"
    printf 'git-ai-commit: prompt file not found: %s\n' "$prompt_file" >&2
    exit 1
  fi

  AGENT_PROMPT=$(cat "$prompt_file")
  if [ -z "$(printf '%s' "$AGENT_PROMPT" | tr -d '[:space:]')" ]; then
    rm -f "$diff_file"
    printf 'git-ai-commit: prompt file is empty: %s\n' "$prompt_file" >&2
    exit 1
  fi
}

run_cursor_agent_prompt() {
  if ! command -v agent >/dev/null 2>&1; then
    printf 'git-ai-commit: cursor agent not found on PATH\n' >&2
    return 127
  fi
  agent -p --output-format text "$1"
}

show_loading_spinner() {
  agent_pid=$1
  spin_i=0
  while kill -0 "$agent_pid" 2>/dev/null; do
    case $spin_i in
      0) c='|' ;;
      1) c='/' ;;
      2) c='-' ;;
      3) c='.' ;;
    esac
    spin_i=$(( (spin_i + 1) % 4 ))
    printf '\rLoading commit message... %s  ' "$c" >&2
    sleep 0.12
  done
  printf '\r\033[K' >&2
}

generate_commit_message() {
  msg_file=$(mktemp) || {
    rm -f "$diff_file"
    printf 'git-ai-commit: mktemp failed\n' >&2
    exit 1
  }

  load_agent_prompt

  (
    prompt=$(printf '%s\n\n%s\n%s\n' \
      "$AGENT_PROMPT" \
      'Staged diff:' \
      "$(cat "$diff_file")")
    run_cursor_agent_prompt "$prompt" >"$msg_file"
  ) &
  agent_pid=$!

  show_loading_spinner "$agent_pid"
  wait "$agent_pid"
  agent_status=$?

  msg=$(cat "$msg_file")
  rm -f "$msg_file"

  if [ "$agent_status" -ne 0 ]; then
    printf 'git-ai-commit: cursor agent failed\n' >&2
    exit "$agent_status"
  fi
  if [ -z "$(printf '%s' "$msg" | tr -d '[:space:]')" ]; then
    printf 'git-ai-commit: empty message from agent\n' >&2
    exit 1
  fi
}

# --- Message formatting -------------------------------------------------------

split_title_and_body() {
  title=$(printf '%s\n' "$msg" | head -n 1)
  body=$(printf '%s\n' "$msg" | tail -n +2)
}

build_explicit_issue_ref() {
  explicit_issue_ref=
  if [ -z "$issue_id" ]; then
    return 0
  fi
  load_issue_prefix
  case $issue_id in
    $ISSUE_PREFIX*) explicit_issue_ref=$issue_id ;;
    *) explicit_issue_ref="$ISSUE_PREFIX$issue_id" ;;
  esac
}

footer_key() {
  case $1 in
    "BREAKING CHANGE:"*)
      printf 'BREAKING CHANGE\n'
      ;;
    *)
      printf '%s\n' "$1" | sed -n 's/^\([A-Za-z-][A-Za-z-]*\):.*/\1/p'
      ;;
  esac
}

footer_value() {
  case $1 in
    "BREAKING CHANGE:"*)
      printf '%s\n' "$1" | sed -n 's/^BREAKING CHANGE:[[:space:]]*//p'
      ;;
    *)
      printf '%s\n' "$1" | sed -n 's/^[A-Za-z-][A-Za-z-]*:[[:space:]]*//p'
      ;;
  esac
}

diff_contains_exact_line() {
  line=$1
  if [ -z "$line" ]; then
    return 1
  fi
  grep -Fqx "$line" "$diff_file" || grep -Fqx "+$line" "$diff_file"
}

diff_contains_token() {
  token=$1
  if [ -z "$token" ]; then
    return 1
  fi
  grep -Fq "$token" "$diff_file"
}

diff_indicates_breaking_change() {
  grep -Eiq 'BREAKING[ -]CHANGE|breaking change' "$diff_file"
}

footer_is_allowed() {
  line=$1
  key=$(footer_key "$line")
  value=$(footer_value "$line")

  case $key in
    Co-authored-by)
      diff_contains_exact_line "$line"
      ;;
    Refs)
      [ -n "$explicit_issue_ref" ] && [ "$value" = "$explicit_issue_ref" ] && return 0
      diff_contains_token "$value"
      ;;
    BREAKING-CHANGE|BREAKING\ CHANGE)
      diff_indicates_breaking_change
      ;;
    *)
      return 1
      ;;
  esac
}

normalize_footer_block() {
  tmp_body_input=$(mktemp) || {
    printf 'git-ai-commit: mktemp failed\n' >&2
    exit 1
  }
  tmp_body_output=$(mktemp) || {
    rm -f "$tmp_body_input"
    printf 'git-ai-commit: mktemp failed\n' >&2
    exit 1
  }

  printf '%s\n' "$body" >"$tmp_body_input"

  footer_block=$(
    awk '
      function supported_footer(line) {
        return line ~ /^(Refs|Co-authored-by|BREAKING-CHANGE):[[:space:]].+/ ||
          line ~ /^BREAKING CHANGE:[[:space:]].+/
      }

      { lines[NR] = $0 }
      END {
        end = NR
        while (end > 0 && lines[end] ~ /^[[:space:]]*$/) end--
        start = end
        footer_count = 0
        all_supported = 1

        while (start > 0 && lines[start] ~ /^([A-Za-z-][A-Za-z-]*|BREAKING CHANGE):[[:space:]].+/) {
          footer_count++
          if (!supported_footer(lines[start])) {
            all_supported = 0
          }
          start--
        }

        if (footer_count > 0 && all_supported && start > 0 && lines[start] ~ /^[[:space:]]*$/) {
          for (i = start + 1; i <= end; i++) print lines[i]
        }
      }
    ' "$tmp_body_input"
  )

  if [ -z "$(printf '%s' "$footer_block" | tr -d '[:space:]')" ]; then
    rm -f "$tmp_body_input" "$tmp_body_output"
    return 0
  fi

  awk '
    function supported_footer(line) {
      return line ~ /^(Refs|Co-authored-by|BREAKING-CHANGE):[[:space:]].+/ ||
        line ~ /^BREAKING CHANGE:[[:space:]].+/
    }

    { lines[NR] = $0 }
    END {
      end = NR
      while (end > 0 && lines[end] ~ /^[[:space:]]*$/) end--
      start = end
      footer_count = 0
      all_supported = 1

      while (start > 0 && lines[start] ~ /^([A-Za-z-][A-Za-z-]*|BREAKING CHANGE):[[:space:]].+/) {
        footer_count++
        if (!supported_footer(lines[start])) {
          all_supported = 0
        }
        start--
      }

      if (footer_count > 0 && all_supported && start > 0 && lines[start] ~ /^[[:space:]]*$/) {
        body_end = start - 1
      } else {
        body_end = NR
      }

      while (body_end > 0 && lines[body_end] ~ /^[[:space:]]*$/) body_end--
      for (i = 1; i <= body_end; i++) print lines[i]
    }
  ' "$tmp_body_input" >"$tmp_body_output"

  body=$(cat "$tmp_body_output")
  filtered_footers=

  printf '%s\n' "$footer_block" | while IFS= read -r footer_line || [ -n "$footer_line" ]; do
    [ -z "$(printf '%s' "$footer_line" | tr -d '[:space:]')" ] && continue
    if footer_is_allowed "$footer_line"; then
      printf '%s\n' "$footer_line"
    fi
  done >"$tmp_body_input"

  filtered_footers=$(cat "$tmp_body_input")
  rm -f "$tmp_body_input" "$tmp_body_output"

  if [ -n "$(printf '%s' "$filtered_footers" | tr -d '[:space:]')" ]; then
    if [ -n "$(printf '%s' "$body" | tr -d '[:space:]')" ]; then
      body=$(printf '%s\n\n%s\n' "$body" "$filtered_footers")
    else
      body=$filtered_footers
    fi
  fi
}

wrap_body_to_100_cols() {
  body=$(printf '%s\n' "$body" | while IFS= read -r line || [ -n "$line" ]; do
    if [ -z "$(printf '%s' "$line" | tr -d '[:space:]')" ]; then
      printf '\n'
    else
      printf '%s\n' "$line" | fold -s -w 100
    fi
  done)
}

load_issue_prefix() {
  configured=$(git config --global ai-commit.issue-prefix 2>/dev/null || true)
  ISSUE_PREFIX=${configured:-$DEFAULT_ISSUE_PREFIX}
}

append_issue_to_title() {
  if [ -z "$issue_id" ]; then
    return 0
  fi
  load_issue_prefix
  case $issue_id in
    $ISSUE_PREFIX*) ref=$issue_id ;;
    *) ref="$ISSUE_PREFIX$issue_id" ;;
  esac
  title="$title ($ref)"
}

# --- Commit (editor review + verbose diff) ------------------------------------

run_commit_with_editor() {
  if [ -n "$(printf '%s' "$body" | tr -d '[:space:]')" ]; then
    git commit -ve -m "$title" -m "$body"
  else
    git commit -ve -m "$title"
  fi
}

run_commit_flow() {
  issue_id=${1:-}

  capture_staged_diff
  generate_commit_message
  split_title_and_body
  build_explicit_issue_ref
  normalize_footer_block
  wrap_body_to_100_cols
  append_issue_to_title
  run_commit_with_editor
  commit_status=$?
  rm -f "$diff_file"
  return "$commit_status"
}

# --- Script location (follow symlinks) ----------------------------------------

script_real_dir() {
  script=$1
  while [ -L "$script" ]; do
    link=$(readlink "$script") || break
    case $link in
      /*) script=$link ;;
      *) script=$(dirname -- "$script")/$link ;;
    esac
  done
  CDPATH= cd -- "$(dirname -- "$script")" && pwd
}

# --- Main ---------------------------------------------------------------------

case "${1:-}" in
  setup)
    exec "$(script_real_dir "$0")/setup"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    run_commit_flow "$@"
    ;;
esac
